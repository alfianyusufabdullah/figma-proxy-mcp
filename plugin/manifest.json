{
  "name": "Figma Proxy MCP",
  "api": "1.0.0",
  "main": "dist/code.js",
  "ui": "ui.html",
  "documentAccess": "dynamic-page",
  "networkAccess": {
    "allowedDomains": ["*"],
    "reasoning": "WebSocket connection to a user-configurable proxy server — host and port are set at runtime by the user inside the plugin",
    "devAllowedDomains": ["*"]
  },
  "enablePrivatePluginApi": true,
  "editorType": ["figma", "dev"],
  "capabilities": ["inspect"],
  "menu": [
    {"name": "Start Proxy", "command": "start"}
  ]
}
